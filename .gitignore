# =============================================================================
# .gitignore — devsecops-demo
# =============================================================================

# ─── Node.js ─────────────────────────────────────────────────────────────────
node_modules/
.npm
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Test & Coverage Output ───────────────────────────────────────────────────
# reports/coverage/ is generated by Jest at build time
reports/coverage/
coverage/

# ─── Security Scan Reports ───────────────────────────────────────────────────
# Generated by OWASP Dependency-Check and Trivy during CI
reports/dependency-check-report.html
reports/dependency-check-report.xml
reports/dependency-check-report.json
reports/trivy-report.html
reports/trivy-report.json

# Keep the reports/ directory itself tracked (via .gitkeep)
!reports/.gitkeep

# ─── Environment / Secrets ───────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
*.cert

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
logs/

# ─── OS Artifacts ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── IDE ─────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.suo
.project
.classpath
